# SOC LAB — Custom Suricata detection rules
# Reconstructed from Rapport_PFA-NGSOC_VF.pdf, Figure 15.
#
# ⚠️ TODO (you need to do this): the report screenshot truncates SIDs and some
# flag/threshold values. Pull the actual rule set directly from your pfSense
# box (Services > Suricata > [WAN interface] > Rules > custom.rules) and
# replace this file with the verified export. The structure/msg text below
# is accurate; exact sid numbers, thresholds, and flow options need
# confirming against your live config.

alert icmp any any -> $HOME_NET any (msg:"SOC LAB - Ping ICMP Detecte"; itype:8; classtype:misc-activity; sid:1000010; rev:1;)

alert tcp any any -> $HOME_NET any (msg:"SOC LAB - Scan Nmap SYN Detecte"; flags:S; threshold:type both, track by_src, count 5, seconds 5; classtype:attempted-recon; sid:1000011; rev:1;)

alert tcp any any -> $HOME_NET 22 (msg:"SOC LAB - Tentative Brute Force SSH Detecte"; flags:S; threshold:type both, track by_src, count 5, seconds 5; classtype:attempted-recon; sid:1000012; rev:1;)

alert http any any -> $HOME_NET any (msg:"SOC LAB - Scanner Web (Nikto) Detecte"; flow:established,to_server; http.user_agent; content:"Nikto"; classtype:web-application-attack; sid:1000013; rev:1;)

alert http any any -> $HOME_NET any (msg:"SOC LAB - Tentative Injection SQL (UNION SELECT)"; flow:established,to_server; content:"UNION SELECT"; nocase; classtype:web-application-attack; sid:1000014; rev:1;)

alert tcp any any -> $HOME_NET 21 (msg:"SOC LAB - Authentification FTP en clair detectee"; flow:established,to_server; content:"USER"; classtype:policy-violation; sid:1000015; rev:1;)

alert http any any -> $HOME_NET any (msg:"SOC LAB - Telechargement Executable Suspect (.exe)"; flow:established,to_server; content:".exe"; http.uri; classtype:policy-violation; sid:1000016; rev:1;)

alert udp any any -> $HOME_NET any (msg:"SOC LAB - Attaque DoS (UDP Flood) Detectee"; threshold:type both, track by_dst, count 100, seconds 5; classtype:attempted-dos; sid:1000017; rev:1;)

# --- End of custom rule set ---
